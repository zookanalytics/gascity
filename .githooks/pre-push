#!/usr/bin/env bash
set -euo pipefail

# Heavy `go test` fan-out runs here, at push time, instead of on every commit
# (#3628). pre-commit previously invoked `make test-fast-parallel` on every
# commit. Its outer shard fan-out can compile ~2.8 GiB test binaries per job,
# so the canonical runner now derives concurrency from both CPU and available
# memory while preserving an explicit LOCAL_TEST_JOBS override. Running the
# suite at push time also fires it only when Go sources actually change.
#
# git feeds "<local ref> <local sha> <remote ref> <remote sha>" per pushed ref
# on stdin (see githooks(5)).

zero="0000000000000000000000000000000000000000"

refs_seen=0
go_changed=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  refs_seen=$((refs_seen + 1))
  # Branch deletion — nothing to test.
  if [ "$local_sha" = "$zero" ]; then
    continue
  fi
  # New remote branch: no cheap base to diff against — run the suite.
  if [ "$remote_sha" = "$zero" ]; then
    go_changed=1
    continue
  fi
  if git diff --name-only "$remote_sha" "$local_sha" -- '*.go' 2>/dev/null | grep -q .; then
    go_changed=1
  fi
done

# Fail closed on a degenerate read. git feeds one ref line per pushed ref on
# stdin (githooks(5)), so reading ZERO lines is not a legitimate "nothing
# changed" — it means the gate cannot see what is being pushed. Distinct from
# "read N refs, none touched .go" below, this is an anomaly: run the suite
# rather than silently passing an unexamined push. A 581-file rebase push once
# slipped through this exact path in 3s with no output, suite never run
# (gc-uz8az).
if [ "$refs_seen" -eq 0 ]; then
  echo "pre-push: no ref lines on stdin — running suite fail-closed (cannot determine changed files)" >&2
  go_changed=1
fi

if [ "$go_changed" -eq 0 ]; then
  # Loud no-op: a skipped gate must be visible in push output. A silent exit 0
  # is indistinguishable from "tests ran and passed" (gc-uz8az).
  echo "pre-push: no Go changes in pushed refs — skipping test suite"
  exit 0
fi

# The Makefile and direct sharded runner share scripts/test-local-job-count as
# their default policy. Do not shadow it here; an explicit override still wins.
exec make test-fast-parallel
