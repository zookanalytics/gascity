#!/usr/bin/env bash

set -euo pipefail

# A fast-suite shard can build a roughly 2.8 GiB test binary. Budget 4 GiB per
# concurrent shard for compiler/linker headroom, cap automatic fan-out at 16,
# and preserve the former three-job safety default when memory is unknowable.
readonly job_memory_kib=$((4 * 1024 * 1024))
readonly max_auto_jobs=16
readonly unknown_memory_jobs=3

# Free scratch space is the third budget, alongside CPU and memory. Every
# concurrent shard writes its own Go $WORK tree — package archives, that same
# ~2.8 GiB test binary, and linker temporaries — under the scratch filesystem,
# so peak disk demand scales with the fan-out exactly like peak memory does.
# Budget the same 4 GiB per shard, since the same test binary dominates both.
#
# Reserve 8 GiB on top: on a Gas City host the scratch volume also carries the
# Dolt data plane, and Go only removes $WORK on a clean exit, so killed shards
# leak their trees until something reaps them. Filling that volume stopped every
# build and every Dolt write fleet-wide (gc-k1b5h), which is far more expensive
# than a slower suite.
readonly job_scratch_kib=$((4 * 1024 * 1024))
readonly reserved_scratch_kib=$((8 * 1024 * 1024))

fail() {
  echo "test-local-job-count: $*" >&2
  exit 1
}

detect_cpus() {
  if [[ -n "${GC_TEST_LOCAL_CPUS:-}" ]]; then
    [[ "$GC_TEST_LOCAL_CPUS" =~ ^[0-9]+$ && "$GC_TEST_LOCAL_CPUS" -gt 0 ]] ||
      fail "GC_TEST_LOCAL_CPUS must be a positive integer"
    printf '%s\n' "$GC_TEST_LOCAL_CPUS"
    return
  fi

  nproc 2>/dev/null ||
    getconf _NPROCESSORS_ONLN 2>/dev/null ||
    sysctl -n hw.ncpu 2>/dev/null ||
    printf '8\n'
}

cgroup_remaining_kib() {
  local root="${1%/}" relative="${2#/}" limit_file="$3" current_file="$4"
  local dir limit current remaining_kib best=0 found=0

  [[ -n "$root" ]] || root=/
  dir="$root"
  if [[ -n "$relative" ]]; then
    dir="$root/$relative"
  fi

  # A leaf may be unlimited while an ancestor enforces the real budget. Walk
  # the process cgroup and every ancestor up to the controller mount.
  while [[ "$dir" == "$root" || "$dir" == "$root/"* ]]; do
    if [[ -r "$dir/$limit_file" && -r "$dir/$current_file" ]]; then
      read -r limit < "$dir/$limit_file" || true
      read -r current < "$dir/$current_file" || true
      if [[ "$limit" =~ ^[0-9]+$ && "$current" =~ ^[0-9]+$ ]]; then
        found=1
        if [[ "$current" -ge "$limit" ]]; then
          remaining_kib=1
        else
          remaining_kib=$(((limit - current + 1023) / 1024))
          if [[ "$remaining_kib" -lt 1 ]]; then
            remaining_kib=1
          fi
        fi
        if [[ "$best" -eq 0 || "$remaining_kib" -lt "$best" ]]; then
          best="$remaining_kib"
        fi
      fi
    fi

    [[ "$dir" == "$root" ]] && break
    dir="${dir%/*}"
  done

  [[ "$found" -eq 1 ]] || return 1
  printf '%s\n' "$best"
}

detect_cgroup_memory_kib() {
  local proc_cgroup="${GC_TEST_LOCAL_PROC_CGROUP:-/proc/self/cgroup}"
  local cgroup_root="${GC_TEST_LOCAL_CGROUP_ROOT:-/sys/fs/cgroup}"
  local relative

  [[ -r "$proc_cgroup" ]] || return 1

  relative="$(awk -F: '$1 == "0" && $2 == "" { print $3; exit }' "$proc_cgroup" 2>/dev/null || true)"
  if [[ -n "$relative" ]] &&
    cgroup_remaining_kib "$cgroup_root" "$relative" memory.max memory.current; then
    return
  fi

  relative="$(awk -F: '$2 ~ /(^|,)memory(,|$)/ { print $3; exit }' "$proc_cgroup" 2>/dev/null || true)"
  [[ -n "$relative" ]] || return 1
  cgroup_remaining_kib "$cgroup_root/memory" "$relative" memory.limit_in_bytes memory.usage_in_bytes
}

detect_memory_kib() {
  if [[ -n "${GC_TEST_LOCAL_MEMORY_KIB+x}" ]]; then
    [[ "$GC_TEST_LOCAL_MEMORY_KIB" =~ ^[0-9]+$ ]] ||
      fail "GC_TEST_LOCAL_MEMORY_KIB must be a non-negative integer"
    if [[ "$GC_TEST_LOCAL_MEMORY_KIB" -gt 0 ]]; then
      printf '%s\n' "$GC_TEST_LOCAL_MEMORY_KIB"
      return
    fi
    return 1
  fi

  local meminfo="${GC_TEST_LOCAL_MEMINFO:-/proc/meminfo}"
  local best=0 candidate total_bytes total_kib
  if [[ -r "$meminfo" ]]; then
    candidate="$(awk '/^MemAvailable:/ { print $2; exit }' "$meminfo" 2>/dev/null || true)"
    if [[ "$candidate" =~ ^[0-9]+$ && "$candidate" -gt 0 ]]; then
      best="$candidate"
    fi
  fi

  # Container or systemd-scope limits can be lower than host MemAvailable.
  # Resolve the process's cgroup path and take its tightest ancestor budget.
  candidate="$(detect_cgroup_memory_kib || true)"
  if [[ "$candidate" =~ ^[0-9]+$ && "$candidate" -gt 0 ]]; then
    if [[ "$best" -eq 0 || "$candidate" -lt "$best" ]]; then
      best="$candidate"
    fi
  fi

  # macOS exposes total rather than readily available memory. Reserve 4 GiB
  # for the OS and interactive work before applying the per-shard budget.
  if [[ "$best" -eq 0 ]]; then
    total_bytes="$(sysctl -n hw.memsize 2>/dev/null || true)"
    if [[ "$total_bytes" =~ ^[0-9]+$ && "$total_bytes" -gt 0 ]]; then
      total_kib=$((total_bytes / 1024))
      if [[ "$total_kib" -gt "$job_memory_kib" ]]; then
        best=$((total_kib - job_memory_kib))
      else
        best=$((total_kib / 2))
      fi
    fi
  fi

  [[ "$best" -gt 0 ]] || return 1
  printf '%s\n' "$best"
}

detect_scratch_dir() {
  local dir="${GOTMPDIR:-}"

  # The toolchain places $WORK under GOTMPDIR when one is configured, so prefer
  # it over TMPDIR; `go env` also surfaces a GOTMPDIR set by `go env -w`, which
  # never reaches this script's environment.
  if [[ -z "$dir" ]]; then
    dir="$(go env GOTMPDIR 2>/dev/null || true)"
  fi
  if [[ -n "$dir" && -d "$dir" ]]; then
    printf '%s\n' "$dir"
    return
  fi

  # The Makefile's TEST_ENV defaults TMPDIR to /var/tmp for every test target
  # (gc-v2z1p), but LOCAL_TEST_JOBS is expanded before that wrapper applies.
  # Repeating the default here keeps the probe on the filesystem the shards
  # will actually write to.
  printf '%s\n' "${TMPDIR:-/var/tmp}"
}

detect_scratch_kib() {
  if [[ -n "${GC_TEST_LOCAL_DISK_KIB+x}" ]]; then
    [[ "$GC_TEST_LOCAL_DISK_KIB" =~ ^[0-9]+$ ]] ||
      fail "GC_TEST_LOCAL_DISK_KIB must be a non-negative integer"
    if [[ "$GC_TEST_LOCAL_DISK_KIB" -gt 0 ]]; then
      printf '%s\n' "$GC_TEST_LOCAL_DISK_KIB"
      return
    fi
    return 1
  fi

  # POSIX `df -Pk` keeps each filesystem on one line and reports 1024-byte
  # blocks, so field 4 is the space available to this user.
  local avail
  avail="$(df -Pk "$1" 2>/dev/null | awk 'NR == 2 { print $4; exit }')" || return 1
  [[ "$avail" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$avail"
}

cpus="$(detect_cpus)"
memory_kib="$(detect_memory_kib || true)"
scratch_dir="$(detect_scratch_dir)"
scratch_kib="$(detect_scratch_kib "$scratch_dir" || true)"
jobs="$cpus"

if [[ -n "$memory_kib" ]]; then
  memory_jobs=$((memory_kib / job_memory_kib))
  if [[ "$memory_jobs" -lt 1 ]]; then
    memory_jobs=1
  fi
  if [[ "$memory_jobs" -lt "$jobs" ]]; then
    jobs="$memory_jobs"
  fi
elif [[ "$jobs" -gt "$unknown_memory_jobs" ]]; then
  jobs="$unknown_memory_jobs"
fi

# An unreadable free-space reading leaves the CPU-and-memory fan-out untouched:
# an unsupported platform or a transient probe failure must not throttle every
# suite, the same fail-open stance the doctor's tmp-scratch-space check takes.
if [[ -n "$scratch_kib" ]]; then
  if [[ "$scratch_kib" -gt "$reserved_scratch_kib" ]]; then
    scratch_jobs=$(((scratch_kib - reserved_scratch_kib) / job_scratch_kib))
  else
    scratch_jobs=0
  fi
  if [[ "$scratch_jobs" -lt 1 ]]; then
    scratch_jobs=1
    # At the floor the fan-out can no longer protect the volume, and a single
    # shard can still exhaust it. Only the operator can reclaim space, so say
    # so rather than failing later mid-link with a bare ENOSPC.
    echo "test-local-job-count: only $((scratch_kib / 1024)) MiB free for build scratch on ${scratch_dir}" \
      "(one shard needs $((job_scratch_kib / 1024)) MiB above the $((reserved_scratch_kib / 1024)) MiB reserve);" \
      "running 1 job anyway — reclaim space or the suite may fail with 'no space left on device'" >&2
  fi
  if [[ "$scratch_jobs" -lt "$jobs" ]]; then
    jobs="$scratch_jobs"
  fi
fi

if [[ "$jobs" -gt "$max_auto_jobs" ]]; then
  jobs="$max_auto_jobs"
fi

printf '%s\n' "$jobs"
