{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GC_BIN}} prime --hook"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GC_BIN}} prime --hook"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GC_BIN}} nudge drain --inject"
          },
          {
            "type": "command",
            "command": "{{GC_BIN}} mail check --inject"
          },
          {
            "type": "command",
            "command": "{{GC_BIN}} transcript check --inject"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GC_BIN}} hook --inject"
          }
        ]
      }
    ]
  }
}
