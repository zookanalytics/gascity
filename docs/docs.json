{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Gas City Docs",
  "logo": {
    "light": "/images/logo-wordmark.svg",
    "dark": "/images/logo-wordmark.svg",
    "href": "https://docs.gascityhall.com"
  },
  "favicon": "/images/favicon.png",
  "navbar": {
    "links": [
      {
        "label": "Gas City Hall",
        "href": "https://gascityhall.com"
      },
      {
        "label": "Discord",
        "icon": "discord",
        "iconType": "brands",
        "href": "https://discord.gg/xHpUGUzZp2"
      },
      {
        "label": "X",
        "icon": "x-twitter",
        "iconType": "brands",
        "href": "https://x.com/gastownhall"
      },
      {
        "label": "GitHub",
        "icon": "github",
        "iconType": "brands",
        "href": "https://github.com/gastownhall/gascity"
      }
    ]
  },
  "colors": {
    "primary": "#c9a84c",
    "light": "#c9a84c",
    "dark": "#b8862d"
