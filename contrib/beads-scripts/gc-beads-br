#!/usr/bin/env bash
# gc-beads-br — Gas City exec beads provider wrapping beads_rust (br CLI).
#
# Usage:
#   export GC_BEADS=exec:/path/to/contrib/beads-scripts/gc-beads-br
#   gc start my-city
#
# Dependencies: br (beads_rust), jq, bash
#
# Label conventions:
#   meta:<keyhex>:<valuehex>  — metadata entries encoded as hex
#   gcref:<valuehex>          — bead Ref encoded as hex
#   gcneed:<valuehex>         — bead Need encoded as hex
#
# br does not yet support native metadata/ref/needs fields that match the
# Gas City exec beads contract, so those values are carried in labels and
# decoded by the exec store on read.
#
# Operations that Gas City composes in Go (exit 2):
#   mol-cook  — composed from Create calls by exec.Store
#   init      — not needed (br init is separate)
#   config-set — not applicable
#   purge     — not supported
set -euo pipefail

op="${1:?usage: gc-beads-br <operation> [args...]}"
shift

# If BR_DIR is set, change to that directory so br uses it as the store root.
if [ -n "${BR_DIR:-}" ]; then
  cd "$BR_DIR"
fi

# join_labels joins an array of labels with commas for br --labels flag.
join_labels() {
  local IFS=","
  echo "$*"
}

# hex_encode returns a label-safe hex encoding. "_" is the sentinel for empty.
hex_encode() {
  if [ -z "${1:-}" ]; then
    printf '_'
    return
  fi
  printf '%s' "$1" | od -An -tx1 -v | tr -d ' \n'
}

# issues_to_gc normalizes br JSON output to the exec store wire format.
issues_to_gc() {
  jq '
    def normalize_status:
      if . == "blocked" or . == "review" or . == "testing" then "open" else . end;
    def issue_to_gc:
      {
        id: .id,
        title: (.title // ""),
        status: ((.status // "open") | normalize_status),
        type: (.issue_type // .type // "task"),
        priority: (.priority // null),
        created_at: .created_at,
        assignee: (.assignee // ""),
        from: (.from // .owner // ""),
        owner: (.owner // ""),
        parent_id: (.parent_id // .parent // ""),
        parent: (.parent // ""),
        ref: (.ref // ""),
        needs: (.needs // []),
        description: (.description // ""),
        labels: (.labels // []),
        metadata: (.metadata // {}),
        dependencies: (.dependencies // [])
      };
    (
      if type == "array" then .
      elif (type == "object" and has("issues")) then .issues
      else [.]
      end
    ) | map(issue_to_gc)
  '
}

issue_to_gc_one() {
  issues_to_gc | jq '.[0]'
}

collect_issue_ids() {
  jq -r '
    if type == "array" then .[]?.id
    elif (type == "object" and has("issues")) then .issues[]?.id
    else .id // empty
    end
  '
}

show_ids_as_gc() {
  if [ "$#" -eq 0 ]; then
    echo '[]'
    return
  fi
  br show --json "$@" | issues_to_gc
}

case "$op" in
  create)
    input=$(cat)
    title=$(echo "$input" | jq -r '.title')
    bead_type=$(echo "$input" | jq -r '.type // "task"')
    parent_id=$(echo "$input" | jq -r '.parent_id // ""')
    ref=$(echo "$input" | jq -r '.ref // ""')
    description=$(echo "$input" | jq -r '.description // ""')
    assignee=$(echo "$input" | jq -r '.assignee // ""')
    from=$(echo "$input" | jq -r '.from // ""')

    # Collect all labels into an array.
    all_labels=()
    # User-provided labels.
    while IFS= read -r label; do
      [ -n "$label" ] && all_labels+=("$label")
    done < <(echo "$input" | jq -r '.labels // [] | .[]')

    # Ref / needs / metadata use label-safe internal encodings.
    [ -n "$ref" ] && all_labels+=("gcref:$(hex_encode "$ref")")
    while IFS= read -r need; do
      [ -n "$need" ] && all_labels+=("gcneed:$(hex_encode "$need")")
    done < <(echo "$input" | jq -r '.needs // [] | .[]')

    while IFS=$'\t' read -r key value; do
      [ -n "$key" ] && all_labels+=("meta:$(hex_encode "$key"):$(hex_encode "$value")")
    done < <(echo "$input" | jq -r '.metadata // {} | to_entries[] | [.key, (.value | tostring)] | @tsv')

    # Build create command.
    cmd_args=(br create --json --type "$bead_type")
    [ -n "$description" ] && cmd_args+=(--description "$description")
    [ -n "$assignee" ] && cmd_args+=(--assignee "$assignee")
    [ -n "$from" ] && cmd_args+=(--owner "$from")
    [ -n "$parent_id" ] && cmd_args+=(--parent "$parent_id")
    if [ ${#all_labels[@]} -gt 0 ]; then
      cmd_args+=(--labels "$(join_labels "${all_labels[@]}")")
    fi
    cmd_args+=("$title")

    created=$("${cmd_args[@]}")
    id=$(printf '%s' "$created" | jq -r '.id')
    br show --json "$id" | issue_to_gc_one
    ;;

  get)
    # br show returns an array; extract the first element.
    br show --json "$1" | issue_to_gc_one
    ;;

  update)
    id="$1"
    input=$(cat)
    cmd_args=(br update --json "$id")

    if echo "$input" | jq -e 'has("title")' >/dev/null; then
      title=$(echo "$input" | jq -r '.title')
      cmd_args+=(--title "$title")
    fi
    if echo "$input" | jq -e 'has("status")' >/dev/null; then
      status=$(echo "$input" | jq -r '.status')
      cmd_args+=(--status "$status")
    fi
    if echo "$input" | jq -e 'has("priority")' >/dev/null; then
      priority=$(echo "$input" | jq -r '.priority')
      cmd_args+=(--priority "$priority")
    fi
    if echo "$input" | jq -e 'has("description")' >/dev/null; then
      description=$(echo "$input" | jq -r '.description')
      cmd_args+=(--description "$description")
    fi
    if echo "$input" | jq -e 'has("assignee")' >/dev/null; then
      assignee=$(echo "$input" | jq -r '.assignee')
      cmd_args+=(--assignee "$assignee")
    fi
    if echo "$input" | jq -e 'has("parent_id")' >/dev/null; then
      parent_id=$(echo "$input" | jq -r '.parent_id')
      cmd_args+=(--parent "$parent_id")
    fi

    # Append labels via --add-label (one per flag).
    while IFS= read -r label; do
      [ -n "$label" ] && cmd_args+=(--add-label "$label")
    done < <(echo "$input" | jq -r '.labels // [] | .[]')

    while IFS= read -r label; do
      [ -n "$label" ] && cmd_args+=(--remove-label "$label")
    done < <(echo "$input" | jq -r '.remove_labels // [] | .[]')

    while IFS=$'\t' read -r key value; do
      [ -n "$key" ] && cmd_args+=(--add-label "meta:$(hex_encode "$key"):$(hex_encode "$value")")
    done < <(echo "$input" | jq -r '.metadata // {} | to_entries[] | [.key, (.value | tostring)] | @tsv')

    "${cmd_args[@]}" > /dev/null
    ;;

  close)
    id="$1"
    current=$(br show --json "$id")
    current_status=$(printf '%s' "$current" | jq -r '.[0].status // ""')
    if [ "$current_status" = "closed" ]; then
      exit 0
    fi
    if ! close_out=$(br close --json "$id" 2>&1); then
      current=$(br show --json "$id" 2>/dev/null || true)
      if printf '%s' "$current" | jq -e '.[0].status == "closed"' >/dev/null 2>&1; then
        exit 0
      fi
      printf '%s\n' "$close_out" >&2
      exit 1
    fi
    ;;

  list)
    list_args=(br list --json --all)
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --status=*)
          list_args+=(--status "${1#--status=}")
          ;;
      esac
      shift
    done
    mapfile -t ids < <("${list_args[@]}" | collect_issue_ids)
    show_ids_as_gc "${ids[@]}"
    ;;

  ready)
    mapfile -t ids < <(br ready --json | collect_issue_ids)
    show_ids_as_gc "${ids[@]}"
    ;;

  children)
    parent_id="$1"
    mapfile -t ids < <(br list --json --all | collect_issue_ids)
    if [ ${#ids[@]} -eq 0 ]; then
      echo '[]'
      exit 0
    fi
    br show --json "${ids[@]}" | jq --arg parent "$parent_id" 'map(select((.parent_id // .parent // "") == $parent))' | issues_to_gc
    ;;

  list-by-label)
    label="$1"
    mapfile -t ids < <(br list --json --all --label "$label" | collect_issue_ids)
    show_ids_as_gc "${ids[@]}"
    ;;

  set-metadata)
    id="$1"
    key="$2"
    value=$(cat)
    br update --json "$id" --add-label "meta:$(hex_encode "$key"):$(hex_encode "$value")" > /dev/null
    ;;

  ensure-ready|shutdown)
    exit 2  # br is always ready, no server lifecycle
    ;;

  mol-cook|init|config-set|purge)
    exit 2  # Composed in Go / not applicable
    ;;

  *)
    exit 2  # Unknown operation
    ;;
esac
